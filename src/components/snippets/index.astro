---
import { db, eq, language, snippet } from "astro:db";
import CodeSnippet from "./code-snippet.astro";

const snippets = await db
    .select({
      id: snippet.id,
      title: snippet.title,
      description: snippet.description,
      language: language.title,
      createdAt: snippet.createdAt,
      updatedAt: snippet.updatedAt,
    })
    .from(snippet)
    .innerJoin(language, eq(snippet.language, language.id));
---

<div class="grid">
  {snippets && snippets.map((codeSnippet) => <CodeSnippet codeSnippet={codeSnippet} />)}
</div>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(500px, 100%), 1fr));
    gap: 20px;
    margin: 0 auto;
  }
</style>